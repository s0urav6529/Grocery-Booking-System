# Copy this file to .env and update values for local development
NODE_ENV=development
PORT=3000
DB_HOST=postgres
DB_PORT=5432
DB_NAME=grocery_booking_db
DB_USER=postgres
DB_PASSWORD=replace_with_secure_password
JWT_SECRET=replace_with_secure_jwt_secret
JWT_EXPIRATION=7d
API_SECURE_KEY=replace_with_secure_api_key
